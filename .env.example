# Search engine config
# Internal services (the docker-compose values are usually fine)
SEARXNG_URL=http://searxng:8080
REDIS_URL=redis://redis:6379

# vLLM (mtkt-controller via Tailscale)
VLLM_BASE_URL=http://mtkt-controller:8100/v1
VLLM_MODEL=openai/gpt-oss-120b

# Public URL (used in metadata, OG tags)
PUBLIC_BASE_URL=https://search.buffy.bot
