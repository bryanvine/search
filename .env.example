# Search engine config
#
# Copy this to .env (gitignored) and fill in for your environment.

# Internal services — these match docker-compose's service hostnames and
# usually don't need to change. SEARXNG_URL points at the pacing gateway;
# set http://searxng:8080 to bypass it (not recommended, see README).
SEARXNG_URL=http://gateway:20080
REDIS_URL=redis://redis:6379

# How long ranked /api/search payloads cache in Redis. Bots that repeat
# queries are served from here without touching the engines.
# SEARCH_CACHE_TTL_S=3600

# Your local vLLM instance (or any OpenAI-compatible /v1 endpoint:
# llama.cpp server, vLLM, Ollama with --openai-compat, LMStudio, etc.)
# VLLM_MODEL must match a model name your endpoint serves.
VLLM_BASE_URL=http://localhost:8100/v1
VLLM_MODEL=your-model

# If the vLLM hostname isn't reachable from inside the container (e.g. it
# lives on a Tailscale/VPN network), declare a docker-compose extra_hosts
# entry by setting these. Otherwise they default to a no-op host-gateway.
# VLLM_HOSTNAME=vllm.local
# VLLM_HOST_IP=10.0.0.42

# Public-facing URL — used in metadata / OG tags.
PUBLIC_BASE_URL=http://localhost:20000

# Optional: per-result "was this snippet AI-written?" checks via a self-hosted
# ai-detector instance (https://github.com/bryanvine/ai-detector). Leave
# DETECTOR_URL empty to hide the feature. host.docker.internal reaches a
# detector running directly on the docker host. DETECTOR_PUBLIC_URL (if set)
# links each verdict badge to its shareable per-signal evidence page.
# DETECTOR_URL=http://host.docker.internal:27000
# DETECTOR_PUBLIC_URL=https://detector.example.com

# SearXNG instance display name and secret. Change the secret in production.
SEARXNG_INSTANCE_NAME=search
SEARXNG_SECRET=change-me-in-production

# SearXNG gateway tuning (see README "SearXNG gateway"). Defaults are sane;
# raise the rate if your engines tolerate it, lower it if they suspend.
# GATEWAY_RATE_PER_MIN=10
# GATEWAY_BURST=4
# GATEWAY_CACHE_TTL_S=1800
# GATEWAY_CACHE_MAX=2000
# GATEWAY_MAX_WAIT_S=20
